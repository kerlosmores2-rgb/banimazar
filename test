<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>اختبار النظام</title>
</head>
<body>
    <h1>اختبار النظام</h1>
    <button onclick="test()">اضغط</button>
    <div id="result"></div>

    <script>
        function test() {
            localStorage.setItem('test', 'يعمل');
            document.getElementById('result').innerHTML = 'تم حفظ البيانات في localStorage: ' + localStorage.getItem('test');
        }
    </script>
</body>
</html>
